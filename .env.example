# PAM configuration — copy to .env and edit.
# Every value has a sensible default; you only need to set what you want to override.

# ─── Core ────────────────────────────────────
# PAM_HOST=0.0.0.0
# PAM_PORT=8400
# PAM_DATA_DIR=./data

# ─── SSL (auto-generated on first boot if missing) ───
# SSL_CERT_FILE=./certs/cert.pem
# SSL_KEY_FILE=./certs/key.pem
# SSL_AUTO_GENERATE=true

# ─── Whisper ─────────────────────────────────
# WHISPER_BACKEND=auto          # auto | cuda | metal | cpu | python
# WHISPER_MODEL=ggml-large-v3-turbo-q5_0.bin
# WHISPER_THREADS=4
# WHISPER_TTL_SECONDS=300

# ─── External binaries (path or name on PATH) ───
# CLAUDE_BIN=claude
# GH_BIN=gh

# ─── Scheduling defaults (overridable at runtime via /settings page) ───
# DEFAULT_TIMEZONE=America/New_York
# DEFAULT_BRIEFING_HOUR=7
# DEFAULT_CHECKIN_HOUR=13
# DEFAULT_HABIT_RESET_HOUR=4

# ─── Optional integrations ───────────────────
# Leave blank to disable. Each integration self-disables cleanly.

# Your email (used as default calendar invite attendee)
# USER_EMAIL=you@example.com

# Gmail briefing (see data/email_credentials.example.json)
# EMAIL_CREDENTIALS_FILE=./data/email_credentials.json

# Google Calendar (see docs for OAuth2 setup)
# GOOGLE_CREDENTIALS_FILE=./data/google_credentials.json
# GOOGLE_TOKEN_FILE=./data/google_token.json

# GitHub CLI — if set, briefing includes a "recent commits" section across this owner's repos
# Requires `gh auth login` on the host
# GITHUB_OWNER=your-github-username

# ─── First-boot seed ─────────────────────────
# Set to false to skip the starter todos/habits/kanban on a fresh install
# SEED_STARTER_DATA=true
