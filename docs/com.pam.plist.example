<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pam</string>
    <key>WorkingDirectory</key>
    <string>/Users/REPLACE_WITH_YOUR_USER/pam</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/REPLACE_WITH_YOUR_USER/pam/.venv/bin/python</string>
        <string>-m</string>
        <string>app.main</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/pam.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/pam.err.log</string>
</dict>
</plist>
